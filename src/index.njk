<main class="md:flex min-h-screen text-white bg-gray-900">
    <section id="information" class="md:max-w-xl bg-gray-800 p-4">
        <header class="mb-3">
            <h1 class="text-6xl text-blue-300">Kelvin Chua</h1>
            <h3 class="text-sm text-gray-400">Undergraduate Student of Computer Science</h3>
        </header>
        <section class="text-center">
            <div class="rounded-xl mb-2 p-2 shadow-lg text-gray-300 bg-gray-700">
                <h2 class="text-blue-400 text-xl text-center">
                &ltcontact&gt
            </h2>
                <div>
                    <a class="hover:text-blue-300 underline" href="/static/resume_without_number.pdf">Resume</a>
                    <div>Email: chuakid@gmail.com</div>
                    <div class="hover:text-blue-300 underline">
                        <a href="https://github.com/chuakid/">Github: chuakid</a>
                    </div>
                    <div class="hover:text-blue-300 underline">
                        <a href="https://www.linkedin.com/in/kelvin-chua-b18187154/">LinkedIn: kelvin-chua-b18187154</a>
                    </div>
                </div>
                <h2 class="text-blue-400 text-xl text-center">&lt/contact&gt</h2>
            </div>

            {% for info in information %}
                <div class="rounded-xl mb-2 p-2 shadow-lg text-gray-300 bg-gray-700">
                    <h2 class="text-blue-400 text-xl text-center">
                &lt{{info.title}}&gt
            </h2>
                    {{info.text}}
                    <h2 class="text-blue-400 text-xl text-center">&lt/{{info.title}}&gt</h2>
                </div>
            {% endfor %}
        </section>
    </section>
    <section class="p-2 flex-wrap md:flex items-start content-start overflow-y flex-grow">
        {% for project in projects %}
            <div class="rounded p-5 mb-2 md:ml-2 bg-gray-800 flex-grow">
                <h3 class="text-blue-300 text-2xl mb-5 ">
                    {{project.title}}
                </h3>
                <p class="mb-5">{{project.description}}</p>
                <div class="mb-5">
                    {% for tag in project.tags %}
                        <span class="inline-block rounded px-2 py-1 mt-1 border-red-700 border">{{tag}}</span>
                    {% endfor %}
                </div>
                <div class="mt-5">
                    {% if project.link %}
                        <a class="inline-block transition-transform transform rounded hover:scale-110 hover:bg-indigo-300 bg-blue-600 mr-2 px-2 py-1" href={{project.link}}>
                    Demo
                    </a>
                    {% endif %}
                    {% if project.source %}
                        <a class="inline-block transition-transform transform rounded hover:scale-110 hover:bg-indigo-300 bg-blue-600 mr-2 px-2 py-1" href={{project.source}}>
                    Source
                </a>
                    {% endif %}
                </div>

            </div>
        {% endfor %}
    </section>
</main>